# Database — use docker-compose for local dev: docker compose up -d
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fountain_dev

# Platform master key for envelope encryption (32 bytes, base64url, no padding)
# Generate: openssl rand 32 | base64 | tr '+/' '-_' | tr -d '='
MASTER_SECRETS_KEY=

# Sprites platform token (never expose to tenants)
SPRITES_TOKEN=

# GitHub OAuth (register at https://github.com/settings/developers)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# SMTP for transactional email (Swoosh)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@fountain.dev

# Claude auth — set EITHER one. CLAUDE_CODE_OAUTH_TOKEN takes precedence
# and bills against a Claude.ai Pro/Team subscription (cheaper for
# personal use); ANTHROPIC_API_KEY uses metered API billing.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=

OPENAI_API_KEY=
GEMINI_API_KEY=
